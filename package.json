    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.5",
    "jsdom": "^29.1.0",
    "msw": "^2.13.6",
    "vite": "^5.4.2",
    "vitest": "^4.1.5"
